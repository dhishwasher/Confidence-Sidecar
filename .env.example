# Upstream provider credentials
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Proxy auth (customers present this key in Authorization header)
# Leave empty to disable auth during local development
SIDECAR_API_KEY=

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./traces.db

# Tuning
TIER1_CONFIDENCE_BAND_LOW=0.3
TIER1_CONFIDENCE_BAND_HIGH=0.7
TIER1_K_SAMPLES=4
TOP_LOGPROBS_COUNT=5

# CONFIDENCE_STREAM_MODE=chunk   # chunk | store_only | disabled
# store_only computes/stores confidence; fetch it via GET /v1/traces/{trace_id}/confidence

LOG_LEVEL=INFO
